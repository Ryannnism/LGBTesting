# Example: single-domain production (HTTPS terminates here, UI + API on one hostname).
# Replace paths, domain, and upstream port before use.
#
#   sudo cp docs/deploy/nginx.conf.example /etc/nginx/sites-available/lgbapp
#   sudo ln -s /etc/nginx/sites-available/lgbapp /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

upstream lgbapp_api {
    server 127.0.0.1:5003;
    keepalive 32;
}

server {
    listen 80;
    server_name app.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name app.example.com;

    # Certbot / your CA
    ssl_certificate     /etc/letsencrypt/live/app.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/app.example.com/privkey.pem;

    client_max_body_size 50m;

    root /var/www/lgbapp/frontend;
    index index.html;

    location /api/ {
        proxy_pass http://lgbapp_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
