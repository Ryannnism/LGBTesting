# Lightsail UAT — copy to /etc/lgbapp/lgbapp.env (chmod 600, root-owned).
# systemd unit loads this via EnvironmentFile= (see lgbapp-api.service.example).

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5003

Database__Provider=SqlServer

# AWS RDS for SQL Server — replace endpoint, database, user, password.
# TrustServerCertificate=True is commonly required for RDS SQL Server UAT.
ConnectionStrings__DefaultConnection=Server=YOUR_INSTANCE.xxxxx.ap-southeast-1.rds.amazonaws.com,1433;Database=LGBApp;User Id=admin;Password=REPLACE;Encrypt=True;TrustServerCertificate=True;

Jwt__Key=GENERATE_WITH_openssl_rand_base64_48
Jwt__Issuer=LGBApp.Backend
Jwt__Audience=LGBApp.Frontend

# Same-origin (nginx serves UI + proxies /api): omit Cors or leave empty.
# Split UI/API hosts only:
# Cors__AllowedOrigins__0=https://uat.yourdomain.com

AllowedHosts=uat.yourdomain.com

# Optional: persistent uploads outside deploy folder
# LGB_UPLOAD_ROOT=/var/data/lgbapp/uploads
